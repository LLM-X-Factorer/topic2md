{
  "name": "@topic2md/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@topic2md/shared": "workspace:*",
    "@mastra/core": "^0.10.0",
    "ai": "^4.3.19",
    "@ai-sdk/openai": "^1.3.23",
    "zod": "^3.23.8",
    "nanoid": "^5.0.9"
  },
  "peerDependencies": {
    "langfuse": "^3.37.0"
  },
  "peerDependenciesMeta": {
    "langfuse": {
      "optional": true
    }
  }
}
